{
  "entities": {
    "PageContent": {
      "title": "Page Content",
      "description": "Dynamic text content for a specific page",
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "Stringified JSON or markdown content for the page"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Course": {
      "title": "Course",
      "description": "University course offering",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["technical", "general", "management"] },
        "duration": { "type": "string" },
        "eligibility": { "type": "string" },
        "fee": { "type": "string" },
        "description": { "type": "string" },
        "careerProspects": { "type": "string" },
        "syllabusHighlights": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "category", "duration", "fee", "description"]
    },
    "NewsEvent": {
      "title": "News Event",
      "description": "University news or event item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "date", "content"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Leadership team member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "designation": { "type": "string" },
        "message": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "designation"]
    },
    "GenericCollection": {
      "title": "Generic Collection",
      "description": "Generic document data",
      "type": "object",
      "additionalProperties": true
    },
    "Setting": {
      "title": "Setting",
      "description": "Global website settings",
      "type": "object",
      "properties": {
        "value": { "type": "string", "description": "Stringified JSON of the setting value" },
        "updatedAt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/pageContents/{pageId}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "General page contents"
    },
    "/courses/{courseId}": {
      "schema": { "$ref": "#/entities/Course" },
      "description": "All university courses"
    },
    "/newsEvents/{eventId}": {
      "schema": { "$ref": "#/entities/NewsEvent" },
      "description": "University news and events"
    },
    "/teamMembers/{memberId}": {
      "schema": { "$ref": "#/entities/TeamMember" },
      "description": "Leadership team members"
    },
    "/departments/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/faculty/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/boardOfGovernors/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/recruiters/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/alumni/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/notices/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/tenders/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/downloads/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/placements/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/examSchedules/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/academicCalendar/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/scholarships/{docId}": { "schema": { "$ref": "#/entities/GenericCollection" } },
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Global website settings like navbar/footer config"
    }
  }
}
